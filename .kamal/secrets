# Values are resolved at deploy time from the environment / local files.
# No literal secrets live here, so this file is safe to commit.

# GHCR personal access token (write:packages), read from a mode-600 file so
# deploys don't depend on shell environment state.
KAMAL_REGISTRY_PASSWORD=$(cat ~/.config/kamal/ghcr-token)

RAILS_MASTER_KEY=$(cat config/master.key)

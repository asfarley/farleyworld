# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Ignore SQLite databases wherever they land (Rails 8 keeps them in /storage,
# but db/*.sqlite3 shows up with older configs and one-off scripts).
*.sqlite3
*.sqlite3-*

# Windows / WSL cruft (this repo lives on an NTFS drive under /mnt/d).
Thumbs.db
Desktop.ini
*:Zone.Identifier
*.Zone.Identifier

# Note: vendor/javascript is intentionally committed — it holds the vendored
# three.js and actioncable builds the importmap depends on.


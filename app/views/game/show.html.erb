<div id="game"
     data-player-id="<%= current_player.id %>"
     data-player-name="<%= current_player.name %>"
     data-room-slug="<%= current_player.room.slug %>">
  <canvas id="game-canvas"></canvas>

  <div id="hud">
    <div id="hud-room" class="hud-panel"></div>
    <div id="hud-online" class="hud-panel"></div>
    <%= button_to "Leave", session_path, method: :delete, id: "hud-leave", form: { id: "hud-leave-form" } %>
  </div>

  <div id="prompt" class="hidden"></div>
  <div id="dialog" class="hidden">
    <div id="dialog-title"></div>
    <div id="dialog-text"></div>
    <div id="dialog-more">▼</div>
  </div>
  <div id="noteboard" class="hidden">
    <div id="noteboard-head">
      <span id="noteboard-title">NOTICE BOARD</span>
      <button id="noteboard-close" type="button" aria-label="Close">✕</button>
    </div>
    <div id="noteboard-sub"></div>
    <div id="noteboard-notes"></div>
    <form id="noteboard-form" autocomplete="off">
      <input id="noteboard-input" type="text" maxlength="140" placeholder="Leave a note…" autocomplete="off">
      <button id="noteboard-post" type="submit">Pin</button>
    </form>
  </div>

  <div id="notices"></div>
  <div id="controls-hint">WASD / ARROWS — walk &nbsp;&nbsp; SPACE — interact</div>

  <div id="touch-controls" class="hidden" aria-hidden="true">
    <div id="touch-pad"><div id="touch-nub"></div></div>
    <button id="touch-action" type="button">✕</button>
  </div>

  <div id="fade"></div>

  <% if Rails.env.development? %>
    <pre id="jslog" style="position:absolute;top:60px;left:12px;color:#ff7070;font-size:11px;max-width:60ch;white-space:pre-wrap;pointer-events:none;"></pre>
    <script>
      window.dbg = m => { document.getElementById("jslog").textContent += m + "\n" }
      window.addEventListener("error", e => {
        const desc = e.message || `resource error: ${e.target?.src || e.target?.href || e.target?.tagName}`
        document.getElementById("jslog").textContent += `${desc} @ ${e.filename || ""}:${e.lineno || ""}\n`
      }, true)
      window.addEventListener("unhandledrejection", e => {
        document.getElementById("jslog").textContent += `unhandled rejection: ${e.reason}\n${e.reason?.stack || ""}\n`
      })
    </script>
  <% end %>
</div>
